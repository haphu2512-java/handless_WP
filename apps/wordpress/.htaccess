# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Handle REST API /wp-json/ requests
RewriteRule ^wp-json/ - [L]
RewriteRule ^wp-json/(.*)$ index.php?rest_route=/wp-json/$1 [QSA,L]

RewriteRule ^index\.php$ - [L]

# add a trailing slash to /wp-admin for fear of generating a 404 if someone does a direct request to /wp-admin
RewriteRule ^wp-admin$ wp-admin/ [R=301,L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^(wp-(content|admin|includes).*) $1 [L]
RewriteRule ^(.*)$ index.php?pagename=$1 [QSA,L]
</IfModule>
# END WordPress

# CORS Headers
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
    Header set Access-Control-Max-Age "3600"
</IfModule>
